{
  "name": "mcp-registry-api",
  "version": "1.0.0",
  "description": "Express API for MCP Server Registry",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run serve:static",
    "build": "npm run build:static",
    "build:server": "npm run clean && tsc",
    "build:static": "npm run clean && npm run copy:static && npm run copy:data",
    "copy:static": "mkdir -p dist && cp -r public/* dist/",
    "copy:data": "mkdir -p dist/data && cp -r data/* dist/data/",
    "start": "npm run serve:static",
    "clean": "rm -rf dist",
    "test": "npm run build:static && node test-api.js",
    "test:server": "npm run build:server && node test-api.js",
    "serve:static": "npm run build:static && cd dist && python3 -m http.server 8000",
    "serve:server": "npm run build:server && node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "setup": "npm install && npm run build"
  },
  "keywords": ["mcp", "registry", "api", "express"],
  "author": "MCP Registry",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  }
}