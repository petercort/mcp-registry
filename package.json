{
  "name": "mcp-registry",
  "version": "1.0.0",
  "description": "A TypeScript-based MCP registry server for GitHub Pages",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node dist/cli.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist docs",
    "serve": "python3 -m http.server 8000 --directory docs",
    "serve:https": "npx http-server docs -p 8443 -S -C cert.pem -K key.pem",
    "serve:node": "node scripts/https-server.js",
    "generate-cert": "openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes -subj '/CN=localhost'",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "registry",
    "typescript",
    "github-pages",
    "static-site"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "yaml": "^2.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}